{
  "name": "inventory-reservation",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @allo/backend\" \"npm run dev -w @allo/frontend\"",
    "dev:backend": "npm run dev -w @allo/backend",
    "dev:frontend": "npm run dev -w @allo/frontend",
    "build": "npm run build -w @allo/backend && npm run build -w @allo/frontend",
    "start": "concurrently \"npm run start -w @allo/backend\" \"npm run start -w @allo/frontend\"",
    "test": "npm run test -w @allo/backend",
    "test:api": "node scripts/api-smoke-test.mjs",
    "test:concurrency": "node scripts/concurrency-test.mjs",
    "db:push": "npm run db:push -w @allo/backend",
    "db:seed": "npm run db:seed -w @allo/backend",
    "db:migrate": "npm run db:migrate -w @allo/backend",
    "db:studio": "npm run db:studio -w @allo/backend",
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}